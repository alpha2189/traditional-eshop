# ============================================================
# Τραντισιοναλ e-shop — Environment Variables
# Αντέγραψε αυτό το αρχείο σε `.env.local` και συμπλήρωσε τις τιμές.
# Το `.env.local` ΔΕΝ γίνεται ποτέ commit (βλ. .gitignore).
# ============================================================

# ---------- SUPABASE ----------
# Supabase Dashboard -> Project Settings -> API
# Το URL του project (π.χ. https://abcdefgh.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# Το "anon / public" key — ασφαλές για τον browser (προστατεύεται από RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Το "service_role" key — ΜΟΝΟ server-side (webhook). ΠΟΤΕ σε NEXT_PUBLIC_*
SUPABASE_SERVICE_ROLE_KEY=

# ---------- STRIPE ----------
# Stripe Dashboard -> Developers -> API keys
# Για go-live: άλλαξε ΜΟΝΟ αυτές τις 3 τιμές από test (sk_test_/pk_test_)
# σε live (sk_live_/pk_live_) και βάλε το webhook secret του live endpoint.
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Από `stripe listen` (τοπικά) ή Dashboard -> Webhooks (production)
STRIPE_WEBHOOK_SECRET=

# ---------- SITE ----------
# Τοπικά: http://localhost:3000 | Production: https://το-domain-σου.gr
NEXT_PUBLIC_SITE_URL=http://localhost:3000
